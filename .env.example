# ─────────────────────────────────────────────────────────────
#  SyntraAid Backend – Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to GitHub.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/syntraaid?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Frontend URL (used in invite & reset-password links)
FRONTEND_URL=http://localhost:3000
